# Sample .env file for docker-compose
# Copy this to .env.local and fill in your values — never commit secrets to git

# Debug mode
DEBUG=false

# HTTP port for formicary server
HTTP_PORT=7777

# S3/MinIO configuration
AWS_DEFAULT_REGION=us-west-2
BUCKET=formicary-artifacts
PREFIX=formicary

# ── Authentication ────────────────────────────────────────────────────────────
# JWT secret: generate with: openssl rand -base64 32
COMMON_AUTH_JWT_SECRET=

# GitHub OAuth (optional - leave empty if not using GitHub auth)
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:7777/auth/github/callback
COMMON_AUTH_GITHUB_CLIENT_ID=
COMMON_AUTH_GITHUB_CLIENT_SECRET=

# Google OAuth (optional - leave empty if not using Google auth)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Callback URL: http://localhost:7777/auth/google/callback
COMMON_AUTH_GOOGLE_CLIENT_ID=
COMMON_AUTH_GOOGLE_CLIENT_SECRET=

# Configuration file path
CONFIG_FILE=/config/formicary-queen.yaml
