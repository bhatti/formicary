# SHELL variant — runs on a bare ant worker with SSH keys and gh auth configured.
# Prerequisites: claude CLI, gh CLI, git, python3, jq, SSH key for GitHub.
#
# Workspace: ~/claude_workspace/<IssueNumber>-<Nonce> (persisted for local inspection)
# Output: tee'd to stdout for streaming logs + saved as artifacts.
# report_stdout: true on all tasks so Formicary streams output in real-time.

job_type: ai-gh-implement
description: "AI agent: plan -> implement -> self-review -> create PR for a GitHub issue"
max_concurrency: 5
timeout: 90m

tasks:
# --- SETUP -------------------------------------------------------------------
- task_type: setup
  method: SHELL
  timeout: 3m
  report_stdout: true
  environment:
    GIT_SSH_COMMAND: "ssh -o StrictHostKeyChecking=no"
  script:
    - |
      #!/bin/bash
      set -euo pipefail
      TASK_DIR="$PWD"
      WS="$HOME/claude_workspace/{{.IssueNumber}}-{{.Nonce}}"
      echo "=== SETUP ==="
      echo "TASK_DIR=$TASK_DIR"
      echo "WS=$WS"
      echo "Issue: #{{.IssueNumber}} {{.IssueTitle}}"
      echo "Repo: {{.GitHubOrg}}/{{.GitHubRepo}}"
      echo "---"

      rm -rf "$WS"
      mkdir -p "$WS"

      SLUG=$(printf '%s' "{{.IssueTitle}}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | cut -c1-30)
      BRANCH="ai/{{.IssueNumber}}-${SLUG}-{{.Nonce}}"
      echo "Branch: $BRANCH"

      echo "Cloning git@github.com:{{.GitHubOrg}}/{{.GitHubRepo}}.git ..."
      git clone --depth=100 "git@github.com:{{.GitHubOrg}}/{{.GitHubRepo}}.git" "$WS/repo"
      cd "$WS/repo"

      git config user.name "{{.GitUserName}}"
      git config user.email "{{.GitUserEmail}}"
      git checkout -b "$BRANCH"
      echo "Branch created: $BRANCH"

      cat > "$WS/repo/ISSUE_CONTEXT.md" <<'ISSUEEOF'
      # Issue #{{.IssueNumber}}: {{.IssueTitle}}

      {{.IssueBody}}
      ISSUEEOF

      echo "--- ISSUE_CONTEXT.md ---"
      cat "$WS/repo/ISSUE_CONTEXT.md"
      echo "---"

      printf 'WS=%s\nBRANCH=%s\n' "$WS" "$BRANCH" > "$TASK_DIR/meta.env"
      BRANCH_LINK="[${BRANCH}](https://github.com/{{.GitHubOrg}}/{{.GitHubRepo}}/tree/${BRANCH})"
      printf '%s\n' "$BRANCH_LINK" > "$TASK_DIR/branch.txt"

      echo "=== SETUP COMPLETE ==="
      echo "Workspace: $WS/repo"
      echo "Branch: $BRANCH"
      ls -la "$WS/repo"
  artifacts:
    paths:
      - meta.env
      - branch.txt
    when: always
  on_completed: plan

# --- PLAN --------------------------------------------------------------------
- task_type: plan
  method: SHELL
  timeout: 15m
  report_stdout: true
  dependencies:
    - setup
  environment:
    MODEL: "{{.PlanModel}}"
  script:
    - |
      #!/bin/bash
      TASK_DIR="$PWD"
      source "$TASK_DIR/meta.env"
      echo "=== PLAN ==="
      echo "WS=$WS MODEL=$MODEL"
      cd "$WS/repo"

      cat > /tmp/plan_prompt.txt <<'PROMPTEOF'
      You are working in a git repository. Read ISSUE_CONTEXT.md for the issue details.

      Create a PLAN.md file at the repo root with an implementation plan.

      Apply the /ygs-wbs skill methodology if available. Otherwise:
      - Explore the codebase (ls, cat files) to understand architecture and conventions
      - Decompose into ordered vertical-slice tasks, each independently testable
      - Write PLAN.md with: ordered task list, description, files to change, acceptance criteria

      IMPORTANT: On the VERY LAST line of your response, output ONLY this JSON:
      {"status":"DONE","task_count":3,"total_complexity":"M","summary":"one line summary"}
      If you cannot proceed: {"status":"BLOCKED","blocked_reason":"specific reason"}
      PROMPTEOF

      echo "--- Prompt ---"
      cat /tmp/plan_prompt.txt
      echo "---"
      echo "Calling claude (model=$MODEL, max-turns=30)..."
      echo ""

      set +e
      claude --print --model "$MODEL" --max-turns 30 \
        "$(cat /tmp/plan_prompt.txt)" 2>&1 | tee "$TASK_DIR/plan_conversation.txt"
      CLAUDE_EXIT=${PIPESTATUS[0]}
      set -e

      echo ""
      echo "=== claude exit=$CLAUDE_EXIT ==="

      # Show what claude produced
      echo "--- git status after plan ---"
      git status
      echo "--- PLAN.md ---"
      cat PLAN.md 2>/dev/null || echo "(PLAN.md not created)"

      # Extract status JSON
      STATUS_JSON=$(grep -oE '\{[^{}]*"status"[^{}]*\}' "$TASK_DIR/plan_conversation.txt" | tail -1 || true)
      [ -z "$STATUS_JSON" ] && STATUS_JSON='{"status":"DONE","task_count":0,"summary":"no status JSON"}'
      printf '%s\n' "$STATUS_JSON" > "$TASK_DIR/plan_result.json"
      echo "Plan result: $STATUS_JSON"

      cp PLAN.md "$TASK_DIR/plan_summary.md" 2>/dev/null || echo "(no PLAN.md)" > "$TASK_DIR/plan_summary.md"

      STATUS=$(echo "$STATUS_JSON" | jq -r '.status // "DONE"')
      [ "$STATUS" = "BLOCKED" ] && exit 2
      exit 0
  artifacts:
    paths:
      - plan_result.json
      - plan_summary.md
      - plan_conversation.txt
    when: always
  on_exit_code:
    COMPLETED: implement
    "2": notify-blocked
  on_failed: notify-blocked

# --- IMPLEMENT ---------------------------------------------------------------
- task_type: implement
  method: SHELL
  timeout: 45m
  report_stdout: true
  dependencies:
    - setup
    - plan
  environment:
    MODEL: "{{.ImplementModel}}"
  script:
    - |
      #!/bin/bash
      TASK_DIR="$PWD"
      source "$TASK_DIR/meta.env"
      echo "=== IMPLEMENT ==="
      echo "WS=$WS MODEL=$MODEL"
      cd "$WS/repo"

      echo "--- workspace state ---"
      ls -la
      echo "--- PLAN.md ---"
      cat PLAN.md 2>/dev/null || echo "(no PLAN.md)"
      echo "--- ISSUE_CONTEXT.md ---"
      cat ISSUE_CONTEXT.md 2>/dev/null || echo "(no ISSUE_CONTEXT.md)"
      echo "---"

      cat > /tmp/impl_prompt.txt <<'PROMPTEOF'
      You are working in a git repository. Implement the plan for the issue.

      Read ISSUE_CONTEXT.md for the issue and PLAN.md for the plan.

      Apply the /ygs-implement skill methodology if available. Otherwise:
      - Execute each task in PLAN.md in order
      - Actually create/modify the files using your tools
      - Run existing tests after each task if a test runner is available
      - Make atomic git commits after each task: git add -A && git commit -m "task: description"
      - If tests fail after 2 fix attempts: stop and report TESTS_FAILING
      - If blocked: stop and report BLOCKED
      - Do NOT add features beyond the plan

      IMPORTANT: You MUST make actual file changes and git commits.
      On the VERY LAST line of your response, output ONLY this JSON:
      {"status":"DONE","files_changed":["file1.go"],"commits":2,"tests_status":"passing"}
      If blocked: {"status":"BLOCKED","blocked_reason":"reason"}
      If tests failing: {"status":"TESTS_FAILING","failing_tests":["TestFoo"]}
      PROMPTEOF

      echo "Calling claude (model=$MODEL, max-turns=100)..."
      echo ""

      set +e
      claude --print --model "$MODEL" --max-turns 100 \
        "$(cat /tmp/impl_prompt.txt)" 2>&1 | tee "$TASK_DIR/impl_conversation.txt"
      CLAUDE_EXIT=${PIPESTATUS[0]}
      set -e

      echo ""
      echo "=== claude exit=$CLAUDE_EXIT ==="

      echo "--- git log (commits on branch) ---"
      git log --oneline main..HEAD 2>/dev/null || git log --oneline -5
      echo "--- git diff --stat ---"
      git diff --stat main 2>/dev/null || true
      echo "--- git status ---"
      git status

      # Save git state as artifacts
      git diff main > "$TASK_DIR/impl_diff.patch" 2>/dev/null || true
      git log --oneline main..HEAD > "$TASK_DIR/impl_commits.txt" 2>/dev/null || true

      # Extract status JSON
      STATUS_JSON=$(grep -oE '\{[^{}]*"status"[^{}]*\}' "$TASK_DIR/impl_conversation.txt" | tail -1 || true)
      [ -z "$STATUS_JSON" ] && STATUS_JSON='{"status":"DONE","files_changed":[],"commits":0}'
      printf '%s\n' "$STATUS_JSON" > "$TASK_DIR/impl_result.json"
      echo "Impl result: $STATUS_JSON"

      STATUS=$(echo "$STATUS_JSON" | jq -r '.status // "DONE"')
      echo "=== IMPLEMENT STATUS: $STATUS ==="
      [ "$STATUS" = "BLOCKED" ] && exit 2
      [ "$STATUS" = "TESTS_FAILING" ] && exit 3
      exit 0
  artifacts:
    paths:
      - impl_result.json
      - impl_conversation.txt
      - impl_diff.patch
      - impl_commits.txt
    when: always
  on_exit_code:
    COMPLETED: review
    "2": notify-blocked
    "3": fix-tests
  on_failed: notify-blocked

# --- FIX-TESTS ---------------------------------------------------------------
- task_type: fix-tests
  method: SHELL
  timeout: 20m
  retry: 2
  delay_between_retries: 30s
  report_stdout: true
  dependencies:
    - setup
    - implement
  environment:
    MODEL: "{{.ImplementModel}}"
  script:
    - |
      #!/bin/bash
      TASK_DIR="$PWD"
      source "$TASK_DIR/meta.env"
      echo "=== FIX-TESTS ==="
      echo "WS=$WS"
      cd "$WS/repo"

      FAILING=$(jq -r '.failing_tests[]? // empty' "$TASK_DIR/impl_result.json" 2>/dev/null || echo "unknown")
      echo "Known failing: $FAILING"

      {
        printf 'Tests are failing. Fix them.\n\nKnown failing tests: %s\n\n' "$FAILING"
        printf 'Instructions:\n'
        printf '1. Run the test suite to see current output\n'
        printf '2. Read each error carefully - do not guess the cause\n'
        printf '3. Fix the root cause\n'
        printf '4. Re-run to verify\n'
        printf '5. git add -A && git commit -m "fix: tests ..."\n\n'
        printf 'On the LAST line output ONLY: {"status":"DONE","fixed_tests":["TestFoo"]}\n'
        printf 'If still failing: {"status":"STILL_FAILING","still_failing":["TestFoo"]}\n'
      } > /tmp/fix_prompt.txt

      echo "Calling claude (model=$MODEL, max-turns=50)..."
      set +e
      claude --print --model "$MODEL" --max-turns 50 \
        "$(cat /tmp/fix_prompt.txt)" 2>&1 | tee "$TASK_DIR/fix_conversation.txt"
      CLAUDE_EXIT=${PIPESTATUS[0]}
      set -e
      echo ""
      echo "=== claude exit=$CLAUDE_EXIT ==="

      STATUS_JSON=$(grep -oE '\{[^{}]*"status"[^{}]*\}' "$TASK_DIR/fix_conversation.txt" | tail -1 || true)
      [ -z "$STATUS_JSON" ] && STATUS_JSON='{"status":"DONE"}'
      printf '%s\n' "$STATUS_JSON" > "$TASK_DIR/fix_result.json"

      STATUS=$(echo "$STATUS_JSON" | jq -r '.status // "DONE"')
      echo "Fix-tests status: $STATUS"
      [ "$STATUS" = "STILL_FAILING" ] && exit 1
      exit 0
  artifacts:
    paths:
      - fix_result.json
      - fix_conversation.txt
    when: always
  on_completed: review
  on_failed: review

# --- REVIEW ------------------------------------------------------------------
- task_type: review
  method: SHELL
  timeout: 15m
  report_stdout: true
  dependencies:
    - setup
    - implement
  environment:
    MODEL: "{{.ReviewModel}}"
  script:
    - |
      #!/bin/bash
      TASK_DIR="$PWD"
      source "$TASK_DIR/meta.env"
      echo "=== REVIEW ==="
      echo "WS=$WS"
      cd "$WS/repo"

      echo "--- commits to review ---"
      git log --oneline main..HEAD 2>/dev/null || echo "(no commits)"
      echo "--- diff stat ---"
      git diff --stat main 2>/dev/null || echo "(no diff)"
      DIFF_SIZE=$(git diff main 2>/dev/null | wc -l || echo "0")
      echo "Diff lines: $DIFF_SIZE"

      if [ "$DIFF_SIZE" -lt 2 ]; then
        echo "No changes to review - skipping"
        printf '{"status":"CLEAN","critical_findings":0,"fixes_applied":0}\n' > "$TASK_DIR/review_result.json"
        echo "Review result: no changes"
        exit 0
      fi

      cat > /tmp/review_prompt.txt <<'PROMPTEOF'
      Self-review the changes on this branch before creating a PR.

      Apply the /ygs-code-review skill methodology if available. Otherwise:

      Pass 1 - Critical (must fix):
      - Correctness bugs, security issues (injection/XSS/hardcoded secrets), missing error handling
      - For each critical finding: fix it, git add -A && git commit -m "review: fix ..."

      Pass 2 - Informational only (do NOT fix): style, naming, clarity

      On the LAST line output ONLY: {"status":"CLEAN","critical_findings":0,"fixes_applied":0}
      If you fixed issues: {"status":"FIXED","critical_findings":2,"fixes_applied":2}
      PROMPTEOF

      echo "Calling claude for review (model=$MODEL, max-turns=20)..."
      set +e
      claude --print --model "$MODEL" --max-turns 20 \
        "$(cat /tmp/review_prompt.txt)" 2>&1 | tee "$TASK_DIR/review_conversation.txt"
      CLAUDE_EXIT=${PIPESTATUS[0]}
      set -e
      echo ""
      echo "=== claude review exit=$CLAUDE_EXIT ==="

      STATUS_JSON=$(grep -oE '\{[^{}]*"status"[^{}]*\}' "$TASK_DIR/review_conversation.txt" | tail -1 || true)
      [ -z "$STATUS_JSON" ] && STATUS_JSON='{"status":"CLEAN","critical_findings":0,"fixes_applied":0}'
      printf '%s\n' "$STATUS_JSON" > "$TASK_DIR/review_result.json"
      echo "Review result: $STATUS_JSON"

      echo "--- final git log ---"
      git log --oneline main..HEAD 2>/dev/null || echo "(no commits)"
  artifacts:
    paths:
      - review_result.json
      - review_conversation.txt
    when: always
  on_completed: create-pr
  on_failed: create-pr

# --- CREATE-PR ---------------------------------------------------------------
- task_type: create-pr
  method: SHELL
  timeout: 5m
  report_stdout: true
  dependencies:
    - setup
    - plan
    - review
  environment:
    GIT_SSH_COMMAND: "ssh -o StrictHostKeyChecking=no"
  script:
    - |
      #!/bin/bash
      set -euo pipefail
      TASK_DIR="$PWD"
      source "$TASK_DIR/meta.env"
      echo "=== CREATE-PR ==="
      echo "BRANCH=$BRANCH"
      cd "$WS/repo"

      # Check if there are actually commits to push
      COMMIT_COUNT=$(git rev-list --count main..HEAD 2>/dev/null || echo "0")
      echo "Commits on branch: $COMMIT_COUNT"

      if [ "$COMMIT_COUNT" -eq 0 ]; then
        echo "ERROR: No commits on branch - nothing to push or PR"
        echo "This means implement did not make any changes."
        echo "--- git log ---"
        git log --oneline -5
        echo "--- git status ---"
        git status
        exit 1
      fi

      echo "Pushing branch..."
      git push origin "$BRANCH"
      echo "Push successful"

      PLAN_SUMMARY=$(jq -r '.summary // "See PLAN.md"' "$TASK_DIR/plan_result.json" 2>/dev/null || echo "See commits")
      REVIEW_STATUS=$(jq -r '.status // "N/A"' "$TASK_DIR/review_result.json" 2>/dev/null || echo "N/A")
      IMPL_COMMITS=$(jq -r '.commits // 0' "$TASK_DIR/impl_result.json" 2>/dev/null || echo "0")

      PR_BODY="Closes #{{.IssueNumber}}

      ## Summary
      ${PLAN_SUMMARY}

      ## Stats
      - Commits: ${IMPL_COMMITS}
      - Self-review: ${REVIEW_STATUS}
      - Models: plan={{.PlanModel}} impl={{.ImplementModel}} review={{.ReviewModel}}"

      echo "Creating PR..."
      PR_URL=$(gh pr create \
        -R "{{.GitHubOrg}}/{{.GitHubRepo}}" \
        --title "AI: {{.IssueTitle}}" \
        --body "$PR_BODY" \
        --base "{{.GitBranch}}" --head "$BRANCH")

      printf '%s\n' "$PR_URL" > "$TASK_DIR/pr_url.txt"
      echo "=== PR CREATED: $PR_URL ==="

      gh issue edit "{{.IssueNumber}}" -R "{{.GitHubOrg}}/{{.GitHubRepo}}" \
        --remove-label "ai-in-progress" --add-label "ai-pr-open" 2>/dev/null || true
  artifacts:
    paths:
      - pr_url.txt
    when: always
  on_completed: cleanup
  on_failed: cleanup

# --- NOTIFY-BLOCKED ----------------------------------------------------------
- task_type: notify-blocked
  method: SHELL
  timeout: 2m
  report_stdout: true
  script:
    - |
      #!/bin/bash
      TASK_DIR="$PWD"
      echo "=== NOTIFY-BLOCKED ==="
      REASON=$(jq -rs '[.[].blocked_reason?, .[].summary?] | map(select(. != null and . != "")) | first // "Unknown"' \
        "$TASK_DIR/plan_result.json" "$TASK_DIR/impl_result.json" 2>/dev/null || echo "Unknown")
      [ -z "$REASON" ] && REASON="Unknown - check Formicary job logs"
      echo "Blocked: $REASON"
      BODY="**AI Agent Blocked**

      Reason: ${REASON}

      Please fix and re-label as ai-ready to retry."
      gh issue comment "{{.IssueNumber}}" -R "{{.GitHubOrg}}/{{.GitHubRepo}}" --body "$BODY" || true
      gh issue edit "{{.IssueNumber}}" -R "{{.GitHubOrg}}/{{.GitHubRepo}}" \
        --remove-label "ai-in-progress" --add-label "needs-human" 2>/dev/null || true
  on_completed: cleanup
  on_failed: cleanup

# --- CLEANUP (always runs) ---------------------------------------------------
- task_type: cleanup
  method: SHELL
  always_run: true
  timeout: 1m
  report_stdout: true
  script:
    - |
      #!/bin/bash
      TASK_DIR="$PWD"
      WS="$HOME/claude_workspace/{{.IssueNumber}}-{{.Nonce}}"
      echo "=== CLEANUP ==="
      echo "WS=$WS"
      if [ -d "$WS" ]; then
        echo "Workspace preserved at: $WS"
        echo "Contents:"
        find "$WS/repo" -maxdepth 2 -not -path '*/.git/*' | head -30
      else
        echo "Workspace not found"
      fi

job_variables:
  PlanModel: "claude-sonnet-4-5"
  ImplementModel: "claude-sonnet-4-5"
  ReviewModel: "claude-sonnet-4-5"
  GitUserName: "Shahzad Bhatti"
  GitUserEmail: "bhatti@plexobject.com"
  GitHubOrg: "bhatti"
  GitHubRepo: "todo-sample"
  GitBranch: "main"
